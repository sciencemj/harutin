{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "하루틴",
  "version": "0.1.0",
  "identifier": "dev.sciencemj.harutin",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "하루틴",
        "width": 1280,
        "height": 860,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNGQ0QyNDMwNjZDQzI0MEQKUldRTkpNeG1NQ1ROUDJMVU1tRnZDcnRhRnpIT25JUHc3LzZQL3pXc1FGejNNU3YvL0dDc1BVVTUK",
      "endpoints": [
        "https://github.com/sciencemj/harutin/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
